<odoo>
    <record id="view_foodflow_config_form" model="ir.ui.view">
        <field name="name">foodflow.config.form</field>
        <field name="model">foodflow.config</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_test_connection" type="object"
                            string="Test Connection" class="btn-secondary"/>
                    <button name="action_sync_now" type="object"
                            string="Sync Now" class="btn-primary"/>
                    <button name="action_pull_menu" type="object" string="Pull Menu"/>
                    <button name="action_push_menu" type="object" string="Push Menu"/>
                    <button name="action_sync_orders" type="object" string="Sync Orders"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="base_url"/>
                        <field name="api_token" password="True"/>
                        <field name="sync_enabled"/>
                        <field name="connector_enabled"/>
                        <field name="sync_interval_minutes"/>
                        <field name="conflict_policy"/>
                        <field name="pos_config_id"/>
                    </group>
                    <group>
                        <field name="last_menu_sync_at"/>
                        <field name="last_order_sync_at"/>
                        <field name="sync_in_progress"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_foodflow_config" model="ir.actions.act_window">
        <field name="name">FoodFlow Connection</field>
        <field name="res_model">foodflow.config</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
