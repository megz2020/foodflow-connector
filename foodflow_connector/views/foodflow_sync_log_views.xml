<odoo>
    <record id="view_foodflow_sync_log_list" model="ir.ui.view">
        <field name="name">foodflow.sync.log.list</field>
        <field name="model">foodflow.sync.log</field>
        <field name="arch" type="xml">
            <list>
                <field name="create_date"/>
                <field name="direction"/>
                <field name="resource"/>
                <field name="created_count"/>
                <field name="updated_count"/>
                <field name="failed_count"/>
            </list>
        </field>
    </record>
    <record id="action_foodflow_sync_log" model="ir.actions.act_window">
        <field name="name">Sync Logs</field>
        <field name="res_model">foodflow.sync.log</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
